# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from: https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# Server-only — never expose to browser
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ─── App Domain ──────────────────────────────────────────────────────────────
# Used for subdomain extraction in middleware.
# Dev: set to "lvh.me" so luxe.lvh.me:3000 works.
# Prod: set to "yourdomain.com" so luxe.yourdomain.com works.
NEXT_PUBLIC_APP_DOMAIN="lvh.me"

# ─── Webhook Auth ─────────────────────────────────────────────────────────────
# Secret key for /api/retell/webhook — checked via x-api-key or Authorization: Bearer
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_API_KEY="replace-with-a-secure-random-string"

# ─── Node environment ────────────────────────────────────────────────────────
NODE_ENV="development"
