# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from: https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# Server-only — never expose to browser
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ─── App Domain ──────────────────────────────────────────────────────────────
# Used for subdomain extraction in middleware.
# Dev: set to "lvh.me" so luxe.lvh.me:3000 works.
# Prod: set to "yourdomain.com" so luxe.yourdomain.com works.
NEXT_PUBLIC_APP_DOMAIN="lvh.me"

# ─── Webhook Auth ─────────────────────────────────────────────────────────────
# Secret key for /api/retell/webhook — checked via x-api-key or Authorization: Bearer
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_API_KEY="replace-with-a-secure-random-string"

# ─── Call Summary Webhook ─────────────────────────────────────────────────────
# Secret for /api/webhooks/retell/call-summary and /api/webhooks/retell/summary
CALL_SUMMARY_WEBHOOK_SECRET="replace-with-a-secure-random-string"

# ─── Dev/Debug Routes ─────────────────────────────────────────────────────────
# Set to "true" to enable /api/dev/* and /api/reports/monthly/preview in production.
# Leave unset or "false" to disable (recommended for production).
ENABLE_DEV_ROUTES="false"

# Key required by /api/dev/crm/test-delivery in production (via x-dev-action-key header).
DEV_ACTION_KEY=""

# ─── Node environment ────────────────────────────────────────────────────────
NODE_ENV="development"
